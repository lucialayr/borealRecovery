(p1 = random_forest_A_plot(timespan))
(p2 = random_forest_B_plot(timespan))
plot_grid(p1, p2, nrow = 1, labels = c("(a)", "(b)"))
ggsave(paste0("plots/results_rf_", timespan, ".pdf"),  width = 12, scale = 0.95)
